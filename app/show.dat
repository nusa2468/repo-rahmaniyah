                                        <div class="btn-group" role="group">
                                            <input type="radio" class="btn-check" name="absensi[<?= $guru['id'] ?>]" id="hadir_<?= $guru['id'] ?>" value="hadir" <?= $status == 'hadir' ? 'checked' : '' ?>>
                                            <label class="btn btn-outline-success" for="hadir_<?= $guru['id'] ?>">Hadir</label>

                                            <input type="radio" class="btn-check" name="absensi[<?= $guru['id'] ?>]" id="sakit_<?= $guru['id'] ?>" value="sakit" <?= $status == 'sakit' ? 'checked' : '' ?>>
