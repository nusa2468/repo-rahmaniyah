        <div class="card shadow mb-4">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-primary">Absensi Tanggal: <?= \CodeIgniter\I18n\Time::parse($tanggal)->toLocalizedString('d MMMM yyyy') ?></h6>
