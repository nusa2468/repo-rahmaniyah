                                            <input type="radio" class="btn-check" name="absensi[<?= $guru['id'] ?>]" id="izin_<?= $guru['id'] ?>" value="izin" <?= $status == 'izin' ? 'checked' : '' ?>>
                                            <label class="btn btn-outline-info" for="izin_<?= $guru['id'] ?>">Izin</label>
                                            
                                            <input type="radio" class="btn-check" name="absensi[<?= $guru['id'] ?>]" id="alpa_<?= $guru['id'] ?>" value="alpa" <?= $status == 'alpa' ? 'checked' : '' ?>>
