<div class="w-full max-w-4xl mx-auto" x-data='{ 
    calcMode: "fixed", 
    jmlSiswa: 0, 
    nominalSatuan: 0,
    siklus: 12,
    total: 0,
    selectedCompName: "",
    komponenList: <?= json_encode($komponen_gaji) ?>,

    updateByComponent(id) {
        const comp = this.komponenList.find(c => c.id == id);
        if (comp) {
            this.selectedCompName = comp.nama_komponen;
            // Jika sifat di DB adalah "variabel", otomatis set mode per_siswa
            this.calcMode = (comp.sifat.toLowerCase() === "variabel") ? "per_siswa" : "fixed";
            this.nominalSatuan = parseInt(comp.nilai_standar).toLocaleString("id-ID");
            this.calculate();
        }
    },
    calculate() {
        let cleanNominal = String(this.nominalSatuan).replace(/\./g, "").replace(/[^0-9]/g, "");
        const nominal = parseInt(cleanNominal) || 0;
        
        if (this.calcMode === "per_siswa") {
            this.total = (parseInt(this.jmlSiswa) || 0) * nominal * (parseInt(this.siklus) || 1);
        } else {
            // Beban Tetap: Nominal x Siklus (misal Gaji Pokok x 12 bulan)
            this.total = nominal * (parseInt(this.siklus) || 1);
        }
    },
    formatRupiah(e) {
        let val = e.target.value.replace(/[^0-9]/g, "");
        this.nominalSatuan = val.replace(/\B(?=(\d{3})+(?!\d))/g, ".");
        this.calculate();
    }
