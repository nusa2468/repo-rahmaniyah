        $routes->post('add/(:num)', 'Kesiswaan::pesertaAdd/$1');
        $routes->delete('delete/(:num)', 'Kesiswaan::pesertaDelete/$1');
    });

    // Pengelolaan OSIS (CRUD)
    $routes->group('osis', static function ($routes) {
        $routes->get('/', 'OsisController::index');
        $routes->get('new', 'OsisController::new');
        $routes->post('/', 'OsisController::create');
        $routes->get('edit/(:num)', 'OsisController::edit/$1');
        $routes->put('update/(:num)', 'OsisController::update/$1');
        $routes->delete('delete/(:num)', 'OsisController::delete/$1');
    });

    // Alumni (CRUD)
    $routes->group('kesiswaan/alumni', static function ($routes) {
        $routes->get('/', 'Kesiswaan::alumni');
        $routes->get('add', 'Kesiswaan::alumniNew');
        $routes->post('create', 'Kesiswaan::alumniCreate');
        $routes->get('edit/(:num)', 'Kesiswaan::alumniEdit/$1');
        $routes->put('update/(:num)', 'Kesiswaan::alumniUpdate/$1');
        $routes->delete('delete/(:num)', 'Kesiswaan::alumniDelete/$1');
