        $routes->get('/', 'Elearning::index');
        $routes->get('new', 'Elearning::new');
        
        // POST '/' untuk create sudah benar dan tidak duplikat dengan 'save'
        $routes->post('/', 'Elearning::create');
        
        $routes->get('(:num)', 'Elearning::show/$1'); // Detail kelas
        $routes->get('edit/(:num)', 'Elearning::edit/$1');
        $routes->put('update/(:num)', 'Elearning::update/$1');
        $routes->delete('delete/(:num)', 'Elearning::delete/$1');

        // STREAM/FORUM
        $routes->post('(:num)/stream/create', 'Elearning::streamCreate/$1');

