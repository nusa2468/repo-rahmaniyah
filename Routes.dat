    // ----------------------
    // --- Kesiswaan (Ekstrakurikuler, OSIS, Alumni, Laporan) ---
    // ----------------------
    $routes->get('kesiswaan', 'Kesiswaan::index'); // Dashboard Kesiswaan

    // Ekskul (CRUD & Penilaian)
    $routes->group('kesiswaan/ekskul', static function ($routes) {
