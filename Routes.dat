        $routes->get('(:num)/tugas/new', 'Elearning::tugasNew/$1');
        $routes->post('tugas/save', 'Elearning::saveTugas');
        $routes->get('tugas/(:num)', 'Elearning::tugasDetail/$1');
        $routes->get('tugas/edit/(:num)', 'Elearning::tugasEdit/$1');
        $routes->get('tugas/delete/(:num)', 'Elearning::deleteTugas/$1');

        // PENILAIAN TUGAS
        $routes->post('tugas/nilai', 'Elearning::nilaiTugas');
    });

    // ----------------------
    // --- HUMAS/PUBLIKASI (Berita, Pengumuman, Agenda, Album Foto, Afiliasi) ---
    // ----------------------
    $routes->group('berita', static function ($routes) {
        $routes->get('/', 'BeritaController::index');
        $routes->get('new', 'BeritaController::new');
        $routes->post('/', 'BeritaController::create');
        $routes->get('edit/(:num)', 'BeritaController::edit/$1');
        $routes->put('update/(:num)', 'BeritaController::update/$1');
        $routes->delete('delete/(:num)', 'BeritaController::delete/$1');
    });

    $routes->group('pengumuman', static function ($routes) {
        $routes->get('/', 'PengumumanController::index');
        $routes->get('new', 'PengumumanController::new');
        $routes->post('/', 'PengumumanController::create');
        $routes->get('edit/(:num)', 'PengumumanController::edit/$1');
        $routes->put('update/(:num)', 'PengumumanController::update/$1');
        $routes->delete('delete/(:num)', 'PengumumanController::delete/$1');
    });

    $routes->group('agenda', static function ($routes) {
        $routes->get('/', 'AgendaController::index');
        $routes->get('new', 'AgendaController::new');
        $routes->post('/', 'AgendaController::create');
        $routes->get('edit/(:num)', 'AgendaController::edit/$1');
        $routes->put('update/(:num)', 'AgendaController::update/$1');
        $routes->delete('delete/(:num)', 'AgendaController::delete/$1');
    });

    $routes->group('albumfoto', static function ($routes) {
        $routes->get('/', 'AlbumFotoController::index');
        $routes->get('new', 'AlbumFotoController::new');
        $routes->post('/', 'AlbumFotoController::create');
        $routes->get('edit/(:num)', 'AlbumFotoController::edit/$1');
        $routes->put('update/(:num)', 'AlbumFotoController::update/$1');
        $routes->delete('delete/(:num)', 'AlbumFotoController::delete/$1');
    });

    $routes->group('afiliasi', static function ($routes) {
        $routes->get('/', 'AffiliateController::index');
        $routes->get('new', 'AffiliateController::new');
        $routes->post('/', 'AffiliateController::create');
        $routes->get('edit/(:num)', 'AffiliateController::edit/$1');
        $routes->put('update/(:num)', 'AffiliateController::update/$1');
        $routes->delete('delete/(:num)', 'AffiliateController::delete/$1');
    });

    // ----------------------
    // --- Kepegawaian (Absensi dan Penggajian) ---
    // ----------------------
    $routes->get('kepegawaian', 'AbsensiGuruController::index'); // Dashboard Kepegawaian

    // Absensi Guru
    $routes->group('absensi-guru', static function ($routes) {
        $routes->get('/', 'AbsensiGuruController::index'); // Form pemilihan tanggal
        $routes->get('(:any)', 'AbsensiGuruController::index/$1'); // View data absensi (GET dinamis)
        $routes->post('kelola', 'AbsensiGuruController::kelola'); // Tampilkan halaman kelola (dari POST tanggal)
        $routes->post('simpan', 'AbsensiGuruController::simpan'); // Simpan/Update absensi
    });

    // Absensi Karyawan
    $routes->group('absensi-karyawan', static function ($routes) {
        $routes->get('/', 'AbsensiKaryawan::index');
        $routes->get('(:any)', 'AbsensiKaryawan::index/$1');
        
        // PERUBAHAN KRUSIAL: Ubah rute 'kelola' menjadi POST (sudah ada di kode sebelumnya, dikonfirmasi)
        $routes->post('kelola', 'AbsensiKaryawan::kelola');
        
        $routes->post('simpan', 'AbsensiKaryawan::simpan');
    });
    
    // --- PENGGAJIAN KARYAWAN NON-GURU (FIXED FOR url_to) ---
    // Controller: GajiKaryawanController
    $routes->group('gaji-karyawan', static function ($routes) {
        // Rute Tampilan
        $routes->get('/', 'GajiKaryawanController::index');
        $routes->get('riwayat', 'GajiKaryawanController::riwayat');
        $routes->get('proses', 'GajiKaryawanController::proses', ['as' => 'GajiKaryawanController::proses']); // Diberi nama

        // Rute Aksi
        $routes->post('generate', 'GajiKaryawanController::generate', ['as' => 'GajiKaryawanController::generate']);
        
        // Rute DETAIL PER KARYAWAN
        // Menangani NIK sebagai segmen (:segment). Diberi nama 'as' agar url_to() bekerja.
        $routes->get('detail/(:segment)', 'GajiKaryawanController::detail/$1', ['as' => 'GajiKaryawanController::detail']);
        
        // Rute Aksi Lain
        $routes->get('slip/(:num)', 'GajiKaryawanController::slip/$1');
        $routes->get('cetakPdf/(:num)', 'GajiKaryawanController::cetakPdf/$1');
    });
    // -----------------------------------------------------------------

    // Rute Komponen Gaji dengan prefix /app (HANYA UNTUK TAMPILAN)
    $routes->group('komponen-gaji', static function ($routes) {
        $routes->get('/', 'KomponenGajiController::index');
        $routes->get('new', 'KomponenGajiController::new');
        $routes->get('edit/(:num)', 'KomponenGajiController::edit/$1');

        // Aksi POST/PUT/DELETE diarahkan ke root path (Section 4)
    });

    // Penggajian (Tampilan Halaman GET)
    // Controller: PenggajianController (Untuk Guru)
    $routes->group('penggajian', static function ($routes) {
        $routes->get('/', 'PenggajianController::index');
        $routes->get('kelola/(:num)', 'PenggajianController::kelola/$1');
        $routes->get('proses', 'PenggajianController::proses');
        $routes->get('riwayat', 'PenggajianController::riwayat');
        $routes->get('slip/(:num)', 'PenggajianController::slip/$1');
        // Rute POST/DELETE diarahkan ke root path (Section 4)
    });

// =========================================================================
// Rute untuk Modul PENGATURAN
// PENTING: Menambahkan 'namespace' untuk mengarahkan rute ke Controller yang ada di sub-folder APPPATH/Controllers/Pengaturan
// =========================================================================
$routes->group('pengaturan', ['namespace' => 'App\Controllers\Pengaturan'], static function ($routes) {
    
    // 1. Rute untuk Pengaturan Umum Sekolah
    // URL: /pengaturan/umum -> UmumSekolah::index()
    $routes->get('umum', 'UmumSekolah::index');

    // ==========================================================
    // 2. PENGATURAN PENGGUNA (Manual Group)
    // ==========================================================
    $routes->group('pengguna', static function ($routes) {
        // READ: Daftar Pengguna (GET: /pengaturan/pengguna)
        $routes->get('/', 'User::index');
        
        // READ: Detail Pengguna (GET: /pengaturan/pengguna/1)
        $routes->get('(:num)', 'User::show/$1');
        
        // CREATE: Menampilkan Form Tambah (GET: /pengaturan/pengguna/new)
        $routes->get('new', 'User::new');
        
        // CREATE: Menyimpan Data Baru (POST: /pengaturan/pengguna)
        $routes->post('/', 'User::store');
        
        // UPDATE: Menampilkan Form Edit (GET: /pengaturan/pengguna/edit/1)
        $routes->get('edit/(:num)', 'User::edit/$1');
        
        // UPDATE: Menyimpan Perubahan Data (PUT: /pengaturan/pengguna/update/1)
        $routes->put('update/(:num)', 'User::update/$1');
        
        // DELETE: Menghapus Data (DELETE: /pengaturan/pengguna/delete/1)
        $routes->delete('delete/(:num)', 'User::delete/$1');
    });
    
    // ==========================================================
    // 3. PENGATURAN HAK AKSES (Manual Group yang Diperbaiki)
    // ==========================================================
    $routes->group('hak_akses', static function ($routes) {
        // READ: Daftar Hak Akses (GET: /pengaturan/hak_akses)
        $routes->get('/', 'HakAkses::index');
        
        // CREATE: Menampilkan Form Tambah (GET: /pengaturan/hak_akses/new)
        $routes->get('new', 'HakAkses::new');
        
        // CREATE: Menampilkan Form Edit (GET: /pengaturan/hak_akses/edit/1)
        $routes->get('edit/(:num)', 'HakAkses::edit/$1');
        
        // CREATE: Menyimpan Data Baru (POST: /pengaturan/hak_akses)
        $routes->post('/', 'HakAkses::store');
        
        // UPDATE: Menyimpan Perubahan Data (PUT: /pengaturan/hak_akses/update/1)
        $routes->put('update/(:num)', 'HakAkses::update/$1');
        
        // DELETE: Menghapus Data (DELETE: /pengaturan/hak_akses/delete/1)
        $routes->delete('delete/(:num)', 'HakAkses::delete/$1');
        
        // SHOW (Optional, jika ada detail): (GET: /pengaturan/hak_akses/1)
        $routes->get('(:num)', 'HakAkses::show/$1');
    });
    
    // 4. Rute untuk Pengaturan Akademik
    $routes->get('akademik-setting', 'AkademikSetting::index');
    
    // 5. Rute untuk Pengaturan Keuangan
    $routes->get('keuangan-setting', 'KeuanganSetting::index');
    
    // 6. Rute untuk Pengaturan Notifikasi
    $routes->get('notifikasi', 'Notifikasi::index');
    
    // 7. Rute untuk Log Aktivitas
    $routes->get('log', 'Log::index');
    
    });

});