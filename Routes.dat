<?php

use CodeIgniter\Router\RouteCollection;

/**
 * @var RouteCollection $routes
 */

// =================================================================
// 1. HALAMAN PUBLIK (Landing Page, Berita, dll.)
// =================================================================
$routes->get('/', 'PublicController::index');
$routes->get('berita/(:segment)', 'PublicController::beritaDetail/$1');

// --- PENDAFTARAN SISWA BARU (PSB) PUBLIK ---
$routes->group('psb', static function ($routes) {
    $routes->get('daftar', 'PendaftaranController::index'); // Menampilkan form pendaftaran
    $routes->post('daftar', 'PendaftaranController::simpan'); // Memproses pendaftaran
    $routes->get('sukses', 'PendaftaranController::sukses'); // Halaman sukses
});

// =================================================================
// 2. OTENTIKASI (Login/Logout Umum dan Admin)
// =================================================================
$routes->get('login', 'AuthController::index'); // Tampilkan form login Admin/Umum
$routes->post('login', 'AuthController::login'); // Proses login Admin/Umum
$routes->get('logout', 'AuthController::logout'); // Logout Admin/Umum

// =================================================================
// 3. PORTAL PENGGUNA (Login Khusus Berdasarkan Role)
// =================================================================
$routes->group('portal', static function ($routes) {
    // Calon Siswa
    $routes->get('calon-siswa/login', 'Portal\CalonSiswaController::login');
    $routes->post('calon-siswa/login', 'Portal\CalonSiswaController::attemptLogin');
    $routes->get('calon-siswa/dashboard', 'Portal\CalonSiswaController::dashboard', ['filter' => 'calon_siswa_auth']);
    $routes->get('calon-siswa/logout', 'Portal\CalonSiswaController::logout');

    // Afiliasi
    $routes->get('afiliasi/login', 'Portal\AffiliateController::login');
    $routes->post('afiliasi/login', 'Portal\AffiliateController::attemptLogin');
    $routes->get('afiliasi/dashboard', 'Portal\AffiliateController::dashboard', ['filter' => 'affiliate_auth']);
    $routes->get('afiliasi/logout', 'Portal\AffiliateController::logout');

    // Guru
    $routes->get('guru/login', 'Portal\GuruController::login');
    $routes->post('guru/login', 'Portal\GuruController::attemptLogin');
    $routes->get('guru/dashboard', 'Portal\GuruController::dashboard', ['filter' => 'guru_auth']);
    $routes->get('guru/logout', 'Portal\GuruController::logout');

    // Siswa
    $routes->get('siswa/login', 'Portal\SiswaController::login');
    $routes->post('siswa/login', 'Portal\SiswaController::attemptLogin');
    $routes->get('siswa/dashboard', 'Portal\SiswaController::dashboard', ['filter' => 'siswa_auth']);
    $routes->get('siswa/logout', 'Portal\SiswaController::logout');
});

// =================================================================
// 4. AREA ADMIN - RUTE UTAMA (ROOT PATH / ) - FILTER 'auth'
//    Digunakan untuk aksi CRUD/AJAX yang tidak perlu prefix '/app'.
// =================================================================
// Ini adalah rute utama untuk Controller Admin
$routes->group('/', ['filter' => 'auth'], static function ($routes) {
    // Rute utama (Dashboard Admin)
    $routes->get('/', 'Home::index');

    // --- KEPEGAWAIAN: Komponen Gaji CRUD (HANYA DI ROOT PATH) ---
    // Aksi POST/PUT/DELETE diarahkan ke sini agar dapat diakses dari AJAX/Form yang tidak menggunakan /app
    $routes->group('komponen-gaji', static function ($routes) {
        $routes->get('/', 'KomponenGajiController::index');
        $routes->get('new', 'KomponenGajiController::new');
        $routes->post('/', 'KomponenGajiController::create'); // POST create
        $routes->get('edit/(:num)', 'KomponenGajiController::edit/$1');
        $routes->put('update/(:num)', 'KomponenGajiController::update/$1'); // PUT update (Membutuhkan Method Spoofing)
        $routes->delete('delete/(:num)', 'KomponenGajiController::delete/$1'); // DELETE (Membutuhkan Method Spoofing)
    });

    // --- PENGGAJIAN: Aksi Penting yang dipanggil dari manapun (ROOT PATH) ---
    $routes->post('penggajian/generate', 'PenggajianController::generate'); // Aksi Generate Gaji
    $routes->post('penggajian/tambah-komponen/(:num)', 'PenggajianController::tambahKomponen/$1'); // Aksi POST
    $routes->delete('penggajian/hapus-komponen/(:num)', 'PenggajianController::hapusKomponen/$1'); // Aksi DELETE
    $routes->get('penggajian/cetakPdf/(:num)', 'PenggajianController::cetakPdf/$1'); // Aksi GET Cetak PDF
});


// =================================================================
// 5. AREA ADMIN - RUTE DENGAN PREFIX '/app' - FILTER 'auth'
//    Digunakan untuk Navigasi Menu / Konsistensi URL tampilan.
// =================================================================
$routes->group('app', ['filter' => 'auth'], static function ($routes) {
